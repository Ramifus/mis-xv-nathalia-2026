---
// Direccion.astro
---

<section class="py-8 px-4 relative" id="seccion-direccion">
  <!-- Flor lateral izquierda -->
  <div
    class="absolute left-0 top-1/2 -translate-y-1/2 pointer-events-none z-0 w-14 sm:w-20 md:w-28"
  >
    <img
      src="/imagenes/florlateral.png"
      alt=""
      class="w-full h-auto object-contain"
    />
  </div>

  <!-- Flor lateral derecha -->
  <div
    class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none z-0 w-14 sm:w-20 md:w-28"
  >
    <img
      src="/imagenes/florlateral.png"
      alt=""
      class="w-full h-auto object-contain scale-x-[-1]"
    />
  </div>

  <div
    class="max-w-sm mx-auto text-center relative z-10"
    id="contenido-direccion"
  >
    <!-- Separador superior -->
    <div class="flex items-center justify-center gap-2 mb-5">
      <div
        class="h-px flex-1"
        style="background: linear-gradient(to right, transparent, #c4882a);"
      >
      </div>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="#c4882a">
        <polygon points="6,0 12,6 6,12 0,6"></polygon>
      </svg>
      <div
        class="h-px flex-1"
        style="background: linear-gradient(to left, transparent, #c4882a);"
      >
      </div>
    </div>

    <!-- Título -->
    <p
      class="font-crimson text-lg sm:text-xl uppercase tracking-[0.3em] font-bold mb-4"
      style="color: #9a6f00;"
    >
      Recepción Social
    </p>

    <!-- Icono castillo -->
    <div class="flex justify-center mb-4" id="icono-direccion">
      <img
        src="/imagenes/castillo.png"
        alt="Lugar del evento"
        class="w-20 h-20 md:w-24 md:h-24 object-contain icono-dorado"
      />
    </div>

    <!-- Info ubicación -->
    <div class="mb-5 space-y-1" id="info-direccion">
      <h3
        class="font-crimson text-2xl sm:text-3xl font-bold"
        style="color: #c4882a;"
      >
        Eventos Yisa
      </h3>
      <p class="font-charm text-lg sm:text-xl" style="color: #762609;">
        Avenida Bolivia
      </p>
      <p
        class="font-crimson text-xl sm:text-2xl font-bold uppercase tracking-wider"
        style="color: #9a6f00;"
      >
        7:00 p.m.
      </p>
    </div>

    <!-- Botón Ver Ubicación -->
    <div class="flex justify-center" id="boton-ubicacion">
      <a
        href="https://maps.app.goo.gl/XSfhHr79VTQiMaSg9"
        target="_blank"
        rel="noopener noreferrer"
        class="boton-dorado group"
      >
        <span class="boton-brillo"></span>
        <svg
          class="w-5 h-5 relative z-10 transition-transform duration-300 group-hover:scale-110"
          fill="white"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
          ></path>
        </svg>
        <span
          class="font-crimson text-base text-white font-semibold relative z-10 tracking-wide uppercase"
        >
          Ver Ubicación
        </span>
      </a>
    </div>

    <!-- Separador inferior -->
    <div class="flex items-center justify-center gap-2 mt-6">
      <div
        class="h-px flex-1"
        style="background: linear-gradient(to right, transparent, #c4882a);"
      >
      </div>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="#c4882a">
        <polygon points="6,0 12,6 6,12 0,6"></polygon>
      </svg>
      <div
        class="h-px flex-1"
        style="background: linear-gradient(to left, transparent, #c4882a);"
      >
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.set("#contenido-direccion", { opacity: 0, y: 30 });

    ScrollTrigger.create({
      trigger: "#seccion-direccion",
      start: "top 85%",
      onEnter: () =>
        gsap.to("#contenido-direccion", {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: "power2.out",
        }),
      onLeaveBack: () =>
        gsap.to("#contenido-direccion", { opacity: 0, y: 30, duration: 0.4 }),
    });
  });
</script>

<style>
  .icono-dorado {
    filter: brightness(0) saturate(100%) invert(62%) sepia(55%) saturate(600%)
      hue-rotate(5deg) brightness(88%) contrast(95%);
  }

  .boton-dorado {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 28px;
    border-radius: 50px;
    overflow: hidden;
    background: #9a6f00;
    box-shadow:
      0 6px 20px rgba(154, 111, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.35s ease;
    text-decoration: none;
  }

  .boton-dorado:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow:
      0 10px 28px rgba(154, 111, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .boton-dorado:active {
    transform: translateY(0) scale(0.98);
  }

  .boton-brillo {
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.25),
      transparent
    );
    transform: skewX(-20deg);
    transition: left 0.5s ease;
  }

  .boton-dorado:hover .boton-brillo {
    left: 130%;
  }
</style>
