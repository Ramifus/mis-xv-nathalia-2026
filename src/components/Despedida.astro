---
// Despedida.astro
---

<!-- FlorSeparador encima del componente -->
<div class="flex justify-center w-full py-2">
  <img src="/imagenes/FlorSeparador.webp" alt="" class="w-32 md:w-48 lg:w-56 h-auto object-contain" />
</div>

<section class="py-8 px-4 relative overflow-hidden" id="seccion-despedida">

  <div class="max-w-lg mx-auto relative z-10">
    <div class="text-center">

      <!-- Separador superior -->
      <div class="flex justify-center mb-6" id="sep-despedida">
        <img src="/imagenes/separador.png" alt="" class="w-40 sm:w-52 h-auto object-contain" />
      </div>

      <!-- CARD -->
      <div
        class="relative rounded-3xl p-6 md:p-8"
        id="card-despedida"
        style="background: rgba(180,120,60,0.13); border: 1px solid rgba(196,136,42,0.25); box-shadow: 0 8px 32px rgba(154,111,0,0.12);"
      >
        <!-- Esquinas decorativas -->
        <div class="absolute top-2 left-2 w-10 h-10 border-t-2 border-l-2" style="border-color:rgba(196,136,42,0.4);"></div>
        <div class="absolute top-2 right-2 w-10 h-10 border-t-2 border-r-2" style="border-color:rgba(196,136,42,0.4);"></div>
        <div class="absolute bottom-2 left-2 w-10 h-10 border-b-2 border-l-2" style="border-color:rgba(196,136,42,0.4);"></div>
        <div class="absolute bottom-2 right-2 w-10 h-10 border-b-2 border-r-2" style="border-color:rgba(196,136,42,0.4);"></div>

        <div class="relative z-10">

          <!-- Mensaje principal -->
          <div id="mensaje-despedida">
            <p class="font-charm text-lg sm:text-xl leading-relaxed mb-5" style="color:#762609;">
              Con la bendición de Dios y el amor de mis padres y mi familia,
              <span class="font-bold" style="color:#c4882a;">me siento muy feliz</span>
              de llegar a este momento tan especial de mi vida. Ahora empieza un camino lleno de
              <span class="font-bold" style="color:#c4882a;">sueños e ilusiones</span>
              que, con mucha fe, humildad y esperanza, deseo cumplir. Quisiera, con inmensa alegría,
              <span class="font-bold" style="color:#c4882a;">compartir el comienzo</span>
              de esta bella etapa junto a todos ustedes.
            </p>

            <!-- Línea decorativa -->
            <div class="flex items-center justify-center gap-3 my-4" id="linea-decorativa">
              <div class="h-px flex-1" style="background:linear-gradient(to right, transparent, #c4882a);"></div>
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#c4882a">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <div class="h-px flex-1" style="background:linear-gradient(to left, transparent, #c4882a);"></div>
            </div>
          </div>

          <!-- Confirmar asistencia -->
          <p class="font-charm text-base sm:text-lg leading-relaxed mb-4" style="color:#762609;" id="texto-confirmar">
            Tu presencia es muy importante para mí. Por favor,
            <span class="font-semibold" style="color:#c4882a;">confirma tu asistencia</span>
            para compartir juntos este día tan especial.
          </p>

          <!-- Botones WhatsApp -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6" id="boton-ubicacion">

            <!-- Quinceañera -->
            <div class="flex flex-col items-center gap-1">
              <span class="font-crimson text-sm font-semibold uppercase tracking-wide" style="color:#9a6f00;">Quinceañera</span>
              <a href="https://wa.me/59161353132?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20los%2015%20a%C3%B1os%20de%20Nathalia.%20Nos%20vemos%20el%20s%C3%A1bado%2006%20de%20junio%2C%20estar%C3%A9%20sin%20falta"
                 target="_blank" rel="noopener noreferrer" class="boton-wa group">
                <span class="boton-brillo-wa"></span>
                <svg class="w-5 h-5 relative z-10 group-hover:scale-110 transition-transform duration-300" fill="white" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span class="font-crimson text-base text-white font-semibold relative z-10 uppercase tracking-wide">Confirmar</span>
              </a>
            </div>

            <!-- Madre -->
            <div class="flex flex-col items-center gap-1">
              <span class="font-crimson text-sm font-semibold uppercase tracking-wide" style="color:#9a6f00;">Madre</span>
              <a href="https://wa.me/59161329304?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20los%2015%20a%C3%B1os%20de%20Nathalia.%20Nos%20vemos%20el%20s%C3%A1bado%2006%20de%20junio%2C%20estar%C3%A9%20sin%20falta"
                 target="_blank" rel="noopener noreferrer" class="boton-wa group">
                <span class="boton-brillo-wa"></span>
                <svg class="w-5 h-5 relative z-10 group-hover:scale-110 transition-transform duration-300" fill="white" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span class="font-crimson text-base text-white font-semibold relative z-10 uppercase tracking-wide">Confirmar</span>
              </a>
            </div>

          </div>

          <!-- Mensaje final -->
          <p class="font-great-vibes text-3xl sm:text-4xl" style="color:#c4882a;" id="mensaje-final">
            ¡Los espero con mucho cariño!
          </p>

        </div>
      </div>

      <!-- Separador inferior -->
      <div class="flex justify-center mt-6">
        <img src="/imagenes/separador.png" alt="" class="w-40 sm:w-52 h-auto object-contain" />
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.set("#sep-despedida", { opacity: 0, y: -20 });
    gsap.set("#card-despedida", { opacity: 0, y: 30, scale: 0.97 });

    ScrollTrigger.create({
      trigger: "#seccion-despedida",
      start: "top 85%",
      onEnter: () => {
        gsap.to("#sep-despedida",  { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" });
        gsap.to("#card-despedida", { opacity: 1, y: 0, scale: 1, duration: 1, ease: "power3.out", delay: 0.1 });
      },
      onLeaveBack: () => {
        gsap.set("#sep-despedida",  { opacity: 0, y: -20 });
        gsap.set("#card-despedida", { opacity: 0, y: 30, scale: 0.97 });
      },
    });

    gsap.to("#linea-decorativa svg", {
      scale: 1.2, duration: 1.5, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1,
    });

    gsap.to("#mensaje-final", {
      textShadow: "0 0 20px rgba(196,136,42,0.4)",
      duration: 2, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1,
    });
  });
</script>

<style>
  .boton-wa {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 50px;
    overflow: hidden;
    background: #9a6f00;
    box-shadow: 0 6px 20px rgba(154,111,0,0.35), inset 0 1px 0 rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.35s ease;
    text-decoration: none;
  }
  .boton-wa:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 10px 28px rgba(154,111,0,0.45), inset 0 1px 0 rgba(255,255,255,0.2);
  }
  .boton-wa:active { transform: translateY(0) scale(0.98); }
  .boton-brillo-wa {
    position: absolute;
    top: 0; left: -60%;
    width: 40%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: skewX(-20deg);
    transition: left 0.5s ease;
  }
  .boton-wa:hover .boton-brillo-wa { left: 130%; }
</style>
