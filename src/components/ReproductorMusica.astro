<!-- REPRODUCTOR COMPACTO — tema dorado -->
<div class="w-full max-w-[320px] sm:max-w-sm mx-auto px-4 pb-2" id="music-player-container">

  <!-- Controles principales -->
  <div
    class="flex items-center justify-center gap-6 sm:gap-8 mb-3"
    id="controls-container"
  >
    <!-- Anterior -->
    <button
      id="prevBtn"
      class="transition-all duration-300 transform hover:scale-110 focus:outline-none"
      style="color: #7a5500;"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M7 6v12l-2-2V8l2-2zm2 6l8-5v10l-8-5z"/>
      </svg>
    </button>

    <!-- Play / Pause — círculo central -->
    <button
      id="playPauseBtn"
      class="relative flex items-center justify-center w-14 h-14 rounded-full transition-all duration-300 transform hover:scale-110 focus:outline-none shadow-md"
      style="background: rgba(154,111,0,0.18); border: 2px solid rgba(154,111,0,0.5);"
    >
      <svg id="play-icon" width="22" height="22" viewBox="0 0 24 24" fill="#7a5500">
        <path d="M8 5v14l11-7z"/>
      </svg>
      <svg id="pause-icon" width="22" height="22" viewBox="0 0 24 24" fill="#7a5500" class="hidden">
        <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
      </svg>
      <!-- Partículas -->
      <div class="absolute inset-0 pointer-events-none" id="heart-particles"></div>
    </button>

    <!-- Siguiente -->
    <button
      id="nextBtn"
      class="transition-all duration-300 transform hover:scale-110 focus:outline-none"
      style="color: #7a5500;"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17 18V6l2 2v8l-2 2zm-2-6L7 7v10l8-5z"/>
      </svg>
    </button>
  </div>

  <!-- Barra de progreso -->
  <div class="px-1" id="progress-container">
    <div class="flex items-center justify-between text-xs mb-1 font-medium" style="color: #7a5500;">
      <span id="currentTime">0:00</span>
      <span id="totalDuration">--:--</span>
    </div>
    <input
      type="range"
      id="progressBar"
      value="0"
      max="100"
      class="w-full h-1 rounded-full appearance-none cursor-pointer slider-dorado"
    />
  </div>

</div>

<!-- Audio -->
<audio id="music-audio" preload="auto">
  <source src="/audio/melo.mp3" type="audio/mpeg" />
</audio>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let isPlaying = false;
  let currentTime = 0;
  let duration = 0;

  document.addEventListener("DOMContentLoaded", () => {

    gsap.set("#music-player-container", { opacity: 0, y: 20 });

    ScrollTrigger.create({
      trigger: "#music-player-container",
      start: "top 100%",
      onEnter: () => animateIn(),
      onEnterBack: () => animateIn(),
      onLeaveBack: () => gsap.to("#music-player-container", { opacity: 0, y: 20, duration: 0.4 }),
    });

    function animateIn() {
      gsap.to("#music-player-container", {
        opacity: 1, y: 0,
        duration: 0.7, ease: "power2.out",
      });
    }

    // Duración real del audio
    const audio = document.getElementById("music-audio");
    if (audio instanceof HTMLAudioElement) {
      audio.addEventListener("loadedmetadata", () => {
        duration = audio.duration;
        updateTimeDisplay();
      });
    }

    // Eventos
    document.getElementById("playPauseBtn")?.addEventListener("click", togglePlay);
    document.getElementById("prevBtn")?.addEventListener("click", () => {
      gsap.to("#prevBtn", { scale: 1.3, duration: 0.1, yoyo: true, repeat: 1 });
    });
    document.getElementById("nextBtn")?.addEventListener("click", () => {
      gsap.to("#nextBtn", { scale: 1.3, duration: 0.1, yoyo: true, repeat: 1 });
    });
    document.getElementById("progressBar")?.addEventListener("input", seekAudio);
  });

  function togglePlay() {
    const audio = document.getElementById("music-audio");
    if (!(audio instanceof HTMLAudioElement)) return;

    const playIcon  = document.getElementById("play-icon");
    const pauseIcon = document.getElementById("pause-icon");
    const btn       = document.getElementById("playPauseBtn");

    if (!isPlaying) {
      audio.play().catch(() => {});
      playIcon?.classList.add("hidden");
      pauseIcon?.classList.remove("hidden");
      gsap.to(btn, { scale: 1.15, duration: 0.15, yoyo: true, repeat: 1 });
      createParticles();
      isPlaying = true;
      startProgress();
    } else {
      audio.pause();
      playIcon?.classList.remove("hidden");
      pauseIcon?.classList.add("hidden");
      isPlaying = false;
    }
  }

  function createParticles() {
    const container = document.getElementById("heart-particles");
    if (!container) return;
    for (let i = 0; i < 5; i++) {
      const p = document.createElement("div");
      p.innerHTML = "✨";
      p.style.cssText = "position:absolute;font-size:10px;pointer-events:none;left:50%;top:50%;transform:translate(-50%,-50%);opacity:0;";
      container.appendChild(p);
      gsap.to(p, {
        opacity: 1, scale: 1.4,
        x: (Math.random() - 0.5) * 80,
        y: (Math.random() - 0.5) * 80,
        duration: 0.7, ease: "power2.out", delay: i * 0.08,
        onComplete: () => gsap.to(p, { opacity: 0, duration: 0.3, onComplete: () => p.remove() }),
      });
    }
  }

  function seekAudio() {
    const bar   = document.getElementById("progressBar");
    const audio = document.getElementById("music-audio");
    if (bar instanceof HTMLInputElement && audio instanceof HTMLAudioElement) {
      audio.currentTime = (Number(bar.value) / 100) * audio.duration;
      updateTimeDisplay();
    }
  }

  function startProgress() {
    const audio = document.getElementById("music-audio");
    if (!(audio instanceof HTMLAudioElement)) return;
    const iv = setInterval(() => {
      if (!isPlaying) { clearInterval(iv); return; }
      currentTime = audio.currentTime;
      duration    = audio.duration || duration;
      if (currentTime >= duration) { isPlaying = false; clearInterval(iv); }
      const bar = document.getElementById("progressBar");
      if (bar instanceof HTMLInputElement)
        bar.value = duration > 0 ? String((currentTime / duration) * 100) : "0";
      updateTimeDisplay();
    }, 200);
  }

  function updateTimeDisplay() {
    const audio = document.getElementById("music-audio");
    const curEl = document.getElementById("currentTime");
    const totEl = document.getElementById("totalDuration");
    if (!(audio instanceof HTMLAudioElement)) return;
    const fmt = (s: number) => `${Math.floor(s/60)}:${String(Math.floor(s%60)).padStart(2,"0")}`;
    if (curEl) curEl.textContent = fmt(audio.currentTime);
    if (totEl && audio.duration) totEl.textContent = fmt(audio.duration);
  }
</script>

<style>
  .slider-dorado {
    background: linear-gradient(to right, rgba(154,111,0,0.5), rgba(154,111,0,0.15));
    outline: none;
  }
  .slider-dorado::-webkit-slider-thumb {
    appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #9a6f00;
    cursor: pointer;
    border: 2px solid rgba(255,255,255,0.7);
    box-shadow: 0 1px 4px rgba(154,111,0,0.4);
  }
  .slider-dorado::-moz-range-thumb {
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #9a6f00;
    border: 2px solid rgba(255,255,255,0.7);
  }
  #playPauseBtn:hover {
    background: rgba(154,111,0,0.28) !important;
  }
</style>
